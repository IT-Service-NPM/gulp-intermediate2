{
	"name": "gulp-intermediate2",
	"type": "module",
	"version": "3.0.7",
	"description": "A gulp helper for tools that need files on disk",
	"keywords": [
		"gulpplugin",
		"gulp",
		"intermediate",
		"filesystem"
	],
	"author": {
		"name": "Sergei S. Betke",
		"email": "Sergey.S.Betke@yandex.ru",
		"url": "https://github.com/sergey-s-betke"
	},
	"homepage": "https://github.com/IT-Service-NPM/gulp-intermediate2",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/IT-Service-NPM/gulp-intermediate2.git"
	},
	"bugs": {
		"url": "https://github.com/IT-Service-NPM/gulp-intermediate2/issues"
	},
	"license": "MIT",
	"engines": {
		"node": ">=22.17"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		"./package.json": "./package.json",
		".": "./dist/index.js",
		"./intermediate": {
			"import": {
				"types": "./dist/lib/intermediate/index.d.ts",
				"default": "./dist/lib/intermediate/index.js"
			}
		},
		"./compat": {
			"import": {
				"types": "./dist/lib/intermediate/index.d.ts",
				"default": "./dist/lib/intermediate/index.js"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc --build --clean && tsc --build",
		"CI": "pnpm run build && pnpm run lint && pnpm run test && pnpm run build:readme:API && pnpm run build:readme",
		"check-exports": "attw --pack .",
		"lint": "tsc && eslint",
		"test": "node --import tsx --experimental-transform-types --experimental-test-module-mocks --experimental-test-coverage --test-reporter=spec --test-reporter=junit --test-reporter=lcov --test-reporter-destination=stdout --test-reporter-destination=test/results/junit-report.xml --test-reporter-destination=coverage/lcov.info --test",
		"test:snapshots": "node --import tsx --experimental-transform-types --experimental-test-module-mocks --test-update-snapshots --test",
		"build:readme:API": "npx api-extractor run --local && npx api-documenter markdown -i temp -o docs",
		"build:readme:examples": "remark test/examples/*/readme.md --output",
		"build:readme:main": "remark .readme.md --output README.md",
		"build:readme": "pnpm run build:readme:examples && pnpm run build:readme:main",
		"build:changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0"
	},
	"packageManager": "pnpm@10.32.1",
	"dependencies": {
		"async-done": "^2.0.0",
		"gulplog": "^2.2.0",
		"nanoid": "^5.1.6",
		"plugin-error": "^2.0.1",
		"stream": "^0.0.3",
		"stream-composer": "^1.0.2",
		"streamx": "^2.23.0",
		"vinyl-fs": "^4.0.2"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@commitlint/cli": "^20.4.4",
		"@commitlint/config-angular": "^20.4.4",
		"@commitlint/config-conventional": "^20.4.4",
		"@commitlint/types": "^20.4.4",
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^9.39.4",
		"@it-service-npm/remark-gfm-admonition": "^2.0.0",
		"@it-service-npm/remark-include": "^5.0.1",
		"@microsoft/api-documenter": "^7.29.7",
		"@microsoft/api-extractor": "^7.57.7",
		"@types/gulp": "^4.0.18",
		"@types/gulp-plumber": "^0.0.37",
		"@types/stream-composer": "file:src\\types\\stream-composer",
		"@types/streamx": "^2.9.5",
		"@types/vinyl": "^2.0.12",
		"@types/vinyl-fs": "^3.0.7",
		"@typescript-eslint/eslint-plugin": "^8.57.0",
		"@typescript-eslint/parser": "^8.57.0",
		"conventional-changelog": "4.0.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-n": "^17.24.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-sonarjs": "^4.0.2",
		"eslint-plugin-tsdoc": "^0.5.2",
		"eslint-plugin-unicorn": "^63.0.0",
		"gulp": "^5.0.1",
		"gulp-cli": "^3.1.0",
		"gulp-plumber": "^1.2.1",
		"remark-alerts": "^0.0.1",
		"remark-cli": "^12.0.1",
		"remark-code-import": "^1.2.0",
		"remark-gfm": "^4.0.1",
		"remark-github-blockquote-alert": "^2.0.1",
		"remark-license": "^6.1.0",
		"remark-lint-code-block-style": "^4.0.1",
		"remark-preset-lint-consistent": "^6.0.1",
		"remark-preset-lint-recommended": "^7.0.1",
		"remark-remove-comments": "^1.1.1",
		"remark-toc": "^9.0.0",
		"remark-typography": "^0.7.3",
		"remark-usage": "^11.0.1",
		"remark-validate-links": "^13.1.0",
		"tsd": "^0.33.0",
		"tsdoc-markdown": "^1.4.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0"
	}
}
